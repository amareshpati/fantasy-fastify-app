{
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch --env-file=.env.dev src/server.ts",
    "build": "rimraf dist && tsc",
    "start": "node --env-file=.env.prod dist/server.js",
    "staging": "cross-env NODE_ENV=staging npm run build && node --env-file=.env.staging dist/server.js",
    "debug:staging": "cross-env NODE_ENV=staging tsx watch --env-file=.env.staging --inspect src/server.ts",
    "prod": "cross-env NODE_ENV=production npm run build && node --env-file=.env.prod dist/server.js",
    "debug:prod": "cross-env NODE_ENV=production tsx watch --env-file=.env.prod --inspect src/server.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "ci": "npm run lint && npm run typecheck && npm run build"
  },
  "dependencies": {
    "@fastify/jwt": "^10.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@prisma/client": "^6.19.2",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.3",
    "picocolors": "^1.1.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.19.2",
    "rimraf": "^6.1.3",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
