{
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/index.ts",
    "build": "rimraf dist && tsc",
    "start": "node dist/index.js",
    "staging": "NODE_ENV=staging npm run build && node dist/index.js",
    "debug:staging": "NODE_ENV=staging tsx watch --inspect src/index.ts",
    "prod": "NODE_ENV=production npm run build && node dist/index.js",
    "debug:prod": "NODE_ENV=production tsx watch --inspect src/index.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "ci": "npm run lint && npm run typecheck && npm run build"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "picocolors": "^1.1.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.19.2",
    "rimraf": "^6.1.3",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
